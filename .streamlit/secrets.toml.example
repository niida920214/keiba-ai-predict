# 一般ユーザー用パスワード（レース予測のみ利用可）
APP_PASSWORD = "ここに一般用パスワード"

# 管理者用パスワード（予測＋管理者パネル。一般用とは別の値にすること）
ADMIN_PASSWORD = "ここに管理者用パスワード"

# クラウドストレージ（Hugging Face Hub）設定 ※任意
# HF_TOKEN   = "hf_..."               # https://huggingface.co/settings/tokens (Write権限)
# HF_REPO_ID = "ユーザー名/keibaai-data"  # 非公開datasetリポジトリ（自動作成されます）

# GitHub Actions 連携（管理者パネルからのパイプライン実行）※任意
# GH_TOKEN = "github_pat_..."  # Fine-grainedトークン: 対象リポジトリの Actions Read/Write
# GH_REPO  = "ユーザー名/keiba-ai-predict"
